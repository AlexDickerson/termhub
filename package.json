{
  "name": "termhub",
  "version": "0.1.0",
  "private": true,
  "description": "A multi-session terminal manager",
  "license": "MIT",
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --target=node20 --external:electron --external:@lydell/node-pty --outdir=dist/main --format=cjs --sourcemap",
    "build:bridge": "esbuild electron/mcp-bridge.ts --bundle --platform=node --target=node20 --outfile=dist/mcp-bridge.js --format=cjs --sourcemap",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:bridge && npm run build:renderer",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && npm run build:main && npm run build:bridge && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev": "concurrently -k -n vite,electron -c blue,magenta \"npm:dev:vite\" \"npm:dev:electron\"",
    "start": "npm run build && electron .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.electron.json",
    "dist:win": "npm run build && electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.alexdickerson.termhub",
    "productName": "TermHub",
    "compression": "normal",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "package.json",
      "!**/*.map"
    ],
    "asarUnpack": [
      "node_modules/@lydell/node-pty/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-${arch}-portable.${ext}"
    }
  },
  "dependencies": {
    "@lydell/node-pty": "1.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
